# ==============================
# 应用配置
# ==============================
APP_NAME=XF-Mold-Quality-Agent
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# ==============================
# 数据库 - PostgreSQL
# ==============================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=moldagent
POSTGRES_PASSWORD=moldagent_secret
POSTGRES_DB=mold_quality

# ==============================
# pgvector
# ==============================
PGVECTOR_DIMENSION=1536

# ==============================
# LLM API 配置（OpenAI 兼容格式）
# ==============================
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=your-llm-model
LLM_VLM_MODEL=your-vlm-model
LLM_EMBEDDING_MODEL=your-embedding-model

# ==============================
# Chroma 向量库
# ==============================
CHROMA_PERSIST_DIR=./chroma_data

# ==============================
# 缓存
# ==============================
CACHE_DIR=./cache
